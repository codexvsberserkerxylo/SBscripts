-- ── Button Logic ──────────────────────────────────────────────────────────────

btn.MouseButton1Click:Connect(function()
	btn.BackgroundColor3 = Color3.fromRGB(35, 95, 45)
	btn.Text = "decompiling ..."
	statusLbl.Text = "working ..."
	statusLbl.TextColor3 = Color3.fromRGB(240, 195, 40)

	task.defer(function()
		local paths = {}
		for i = 1, activeTabs do
			local t = pathBoxes[i].Text:match("^%s*(.-)%s*$")
			if t and #t > 0 then paths[#paths + 1] = t end
		end

		local varName = VB.Text:match("^%s*(.-)%s*$")

		-- Resolve mode
		local currentMode = modeStates[modeIdx]
		local isDefMode   -- nil = auto-detect per module
		if currentMode == "definitions" then
			isDefMode = true
			if #varName == 0 then varName = "defToWord" end
		elseif currentMode == "wordlist" then
			isDefMode = false
			if #varName == 0 then varName = "GwlWords" end
		else
			-- auto: nil passed, each module decides for itself
			isDefMode = nil
			if #varName == 0 then varName = "GwlWords" end
		end

		print("\n" .. SEP)
		log(("start  %d path(s)  |  var='%s'  |  mode=%s"):format(#paths, varName, currentMode))
		print(SEP)

		if #paths == 0 then
			wlog("no paths entered")
			statusLbl.Text = "enter at least one module path"
			statusLbl.TextColor3 = Color3.fromRGB(255, 70, 70)
			btn.BackgroundColor3 = Color3.fromRGB(55, 150, 70)
			btn.Text = "format + copy to clipboard"
			notify("lunar formatter", "enter at least one module path", 4, "error")
			return
		end

		-- In auto mode, we need to handle mixed tables carefully.
		-- Each module is processed separately and we merge only same-type entries.
		-- For simplicity in auto mode: if ANY module is def-type, warn about mixing.
		local T0 = os.clock()
		local ok, output, lines, bytes = pcall(run, paths, varName, isDefMode)
		local elapsed = os.clock() - T0
		print(SEP)

		if ok and output and #output > 0 then
			local cbOk, cbErr = pcall(setclipboard, output)
			if cbOk then
				log(("copied!  %d lines  |  %d bytes  |  %.4fs"):format(lines, bytes, elapsed))
				statusLbl.Text = ("copied!  %d lines  |  %.3fs"):format(lines, elapsed)
				statusLbl.TextColor3 = Color3.fromRGB(75, 255, 95)
				notify("lunar formatter", ("copied!  %d lines  |  %.3fs"):format(lines, elapsed), 5, "success")
			else
				wlog("clipboard failed: " .. tostring(cbErr))
				print("\n" .. output .. "\n")
				statusLbl.Text = ("printed to console  |  %d lines  |  %.3fs"):format(lines, elapsed)
				statusLbl.TextColor3 = Color3.fromRGB(255, 180, 40)
				notify("lunar formatter", "printed to console (no clipboard)", 5, "warn")
			end
		else
			local errMsg = not ok and tostring(output) or "no output produced"
			wlog("failed: " .. errMsg)
			statusLbl.Text = "error, check console."
			statusLbl.TextColor3 = Color3.fromRGB(255, 55, 55)
			notify("lunar formatter", "error: " .. errMsg:sub(1, 55), 6, "error")
		end

		print(SEP .. "\n")
		btn.BackgroundColor3 = Color3.fromRGB(55, 150, 70)
		btn.Text = "format + copy to clipboard"
	end)
end)

refreshUI()

task.wait(0.1)
notify("lunar formatter", "lunar formatter is ready!", 4, "success")
