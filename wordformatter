-- ─── Core Logic ──────────────────────────────────────────────────────────────

local function resolvePath(raw)
	local parts = {}
	for p in raw:match("^%s*(.-)%s*$"):gmatch("[^%.]+") do parts[#parts + 1] = p end
	local cur = game
	for i, part in ipairs(parts) do
		if i == 1 and part:lower() == "game" then
		else
			local child = cur:FindFirstChild(part)
			if not child then
				local ok, svc = pcall(game.GetService, game, part)
				child = ok and svc or nil
			end
			if not child then return nil, ("no child '%s' at step %d"):format(part, i) end
			cur = child
		end
	end
	return cur, nil
end

local function getSource(obj)
	if decompile then
		local ok, src = pcall(decompile, obj)
		if ok and type(src) == "string" and #src > 10 then return src, nil end
		wlog("  decompile() gave nothing, trying getscriptbytecode ...")
	end
	if getscriptbytecode then
		local ok, bc = pcall(getscriptbytecode, obj)
		if ok and type(bc) == "string" and #bc > 0 then return bc, nil end
	end
	return nil, "no decompiler available"
end

-- ─── Definition format detector ──────────────────────────────────────────────
-- Returns true if the source looks like a word→definition table
-- e.g.  word = "[Noun] A definition.";
local function isDefinitionSource(src)
	local defMatches = 0
	for _ in src:gmatch('%[%s*[Nn]oun%s*%]') do defMatches = defMatches + 1 end
	for _ in src:gmatch('%[%s*[Vv]erb%s*%]') do defMatches = defMatches + 1 end
	for _ in src:gmatch('%[%s*[Aa]djective%s*%]') do defMatches = defMatches + 1 end
	for _ in src:gmatch('%[%s*[Aa]dverb%s*%]') do defMatches = defMatches + 1 end
	return defMatches >= 3
end

-- ─── Parse word→definition entries ───────────────────────────────────────────
-- Handles:
--   word = "definition";
--   ["word"] = "definition";
--   word = 'definition';
local function parseDefinitionEntries(src)
	local entries = {}
	local seen = {}

	local function add(word, def)
		if not word or not def then return end
		word = word:match("^%s*(.-)%s*$")
		def  = def:match("^%s*(.-)%s*$")
		-- skip Lua keywords and short/empty results that aren't real words
		local luaKeywords = {["local"]=true,["return"]=true,["end"]=true,["function"]=true,
		                     ["if"]=true,["then"]=true,["else"]=true,["for"]=true,
		                     ["do"]=true,["while"]=true,["repeat"]=true,["until"]=true,
		                     ["true"]=true,["false"]=true,["nil"]=true,["not"]=true,
		                     ["and"]=true,["or"]=true,["in"]=true}
		if not word or #word == 0 or luaKeywords[word] then return end
		if not def or #def == 0 then return end
		if not seen[word] then
			seen[word] = true
			entries[#entries + 1] = {word = word, def = def}
		end
	end

	-- Priority 1: bracketed key with double quotes:  ["word"] = "definition";
	for word, def in src:gmatch('%["([A-Za-z][A-Za-z0-9_]*)"%]%s*=%s*"(.-)"') do
		add(word, def)
	end
	-- Priority 2: bracketed key with single quotes:  ['word'] = 'definition';
	for word, def in src:gmatch("%['([A-Za-z][A-Za-z0-9_]*)']%s*=%s*'(.-)'") do
		add(word, def)
	end
	-- Priority 3: bare key with double quotes — must be indented (tab or spaces) to avoid matching top-level locals
	-- Pattern: start of line with whitespace, then word = "..."
	for word, def in src:gmatch('\n%s+([A-Za-z][A-Za-z0-9_]*)%s*=%s*"(.-)"') do
		add(word, def)
	end
	for word, def in src:gmatch('\n%s+([A-Za-z][A-Za-z0-9_]*)%s*=%s*\'(.-)\'') do
		add(word, def)
	end

	return entries
end

-- ─── Format defToWord table ───────────────────────────────────────────────────
local COL_DEF = 48

local function formatDefToWord(entries, varName)
	local lines = {("local %s = {"):format(varName)}
	for _, e in ipairs(entries) do
		if not e.word or not e.def then continue end
		-- escape any quotes in the definition string
		local safeDef = e.def:gsub('"', '\\"')
		local kPart = ('\t["%s"]'):format(e.word)
		local padding = string.rep(" ", math.max(1, COL_DEF - #kPart))
		lines[#lines + 1] = ('%s%s= "%s",'):format(kPart, padding, safeDef)
	end
	lines[#lines + 1] = "}"
	return table.concat(lines, "\n")
end

-- ─── Parse word→soundid entries (original format) ────────────────────────────
local COL = 52

local function parseEntries(src)
	local entries = {}
	local seen = {}

	local function add(word, id)
		if not seen[id] then
			seen[id] = true
			entries[#entries + 1] = {word = word, id = id}
		end
	end

	for word, id in src:gmatch('"([A-Za-z][A-Za-z0-9_]*)"[,]?\n?%s*(%d%d%d%d%d+)') do add(word, id) end
	for word, id in src:gmatch('{%s*"([A-Za-z][A-Za-z0-9_]*)",%s*(%d%d%d%d%d+)') do add(word, id) end
	for word, id in src:gmatch('([A-Za-z][A-Za-z0-9_]*)%s*=%s*(%d%d%d%d%d+)') do add(word, id) end
	for id, word in src:gmatch('%[(%d%d%d%d%d+)%]%s*=%s*"([A-Za-z][A-Za-z0-9_]*)"') do add(word, id) end

	local capturedIds = {}
	for _, e in ipairs(entries) do capturedIds[e.id] = true end
	for id in src:gmatch('(%d%d%d%d%d+)') do
		if not capturedIds[id] then
			capturedIds[id] = true
			entries[#entries + 1] = {word = "null", id = id}
		end
	end

	return entries
end

local function formatGwl(entries, varName)
	local lines = {("local %s = {"):format(varName)}
	for _, e in ipairs(entries) do
		local kPart = ('\t["rbxassetid://%s"]'):format(e.id)
		local padding = string.rep(" ", math.max(1, COL - #kPart))
		lines[#lines + 1] = ('%s%s= "%s",'):format(kPart, padding, e.word)
	end
	lines[#lines + 1] = "}"
	return table.concat(lines, "\n")
end

-- ─── Process one module (auto-detects format) ────────────────────────────────

local function processOne(pathStr, idx, total, all, seenGlobal, isDefMode)
	log(("module %d/%d  →  %s"):format(idx, total, pathStr))
	local obj, pathErr = resolvePath(pathStr)
	if not obj then wlog("  path error: " .. pathErr); return end
	if not (obj:IsA("ModuleScript") or obj:IsA("LocalScript") or obj:IsA("Script")) then
		wlog("  not a script: " .. obj.ClassName); return
	end
	log("  decompiling ...")
	local src, deErr = getSource(obj)
	if not src then wlog("  " .. deErr); return end
	log(("  got %d bytes"):format(#src))

	-- Auto-detect or use forced mode
	local useDefMode = isDefMode
	if useDefMode == nil then
		useDefMode = isDefinitionSource(src)
		if useDefMode then
			log("  detected: definition table (word → definition)")
		else
			log("  detected: wordlist table (soundid → word)")
		end
	end

	if useDefMode then
		local entries = parseDefinitionEntries(src)
		log(("  parsed %d definition entries"):format(#entries))
		if #entries == 0 then wlog("no definition entries found"); return end
		local added = 0
		for i, e in ipairs(entries) do
			local key = e.word
			if not seenGlobal[key] then
				seenGlobal[key] = true
				all[#all + 1] = e
				added = added + 1
			end
			if i % 10 == 0 or i == #entries then pbar(("mod%d"):format(idx), i, #entries) end
		end
		log(("  added %d  |  %d dupes skipped"):format(added, #entries - added))
	else
		local entries = parseEntries(src)
		log(("  parsed %d entries"):format(#entries))
		if #entries == 0 then wlog("no entries found"); return end
		local added = 0
		for i, e in ipairs(entries) do
			if not seenGlobal[e.id] then
				seenGlobal[e.id] = true
				all[#all + 1] = e
				added = added + 1
			end
			if i % 10 == 0 or i == #entries then pbar(("mod%d"):format(idx), i, #entries) end
		end
		log(("  added %d  |  %d dupes skipped"):format(added, #entries - added))
	end
end

local function run(paths, varName, isDefMode)
	local all = {}
	local seen = {}
	for idx, pathStr in ipairs(paths) do
		print(SEP)
		processOne(pathStr, idx, #paths, all, seen, isDefMode)
	end
	print(SEP)
	log(("Total: %d entries  |  formatting ..."):format(#all))
	local t0 = os.clock()
	local output
	if isDefMode then
		output = formatDefToWord(all, varName)
	else
		output = formatGwl(all, varName)
	end
	local secs = os.clock() - t0
	local lines = select(2, output:gsub("\n", "")) + 1
	log(("Done  %.4fs  |  %d lines  |  %d bytes"):format(secs, lines, #output))
	return output, lines, #output
end

