	local function autoSayWord(word)
		if not state.autoSayEnabled then return end
		if not word or word == "" then return end
		local delay = math.max(state.autoSayDelay, 0)
		task.delay(delay, function()
			if not state.autoSayEnabled then return end
			local ok, err = pcall(function()
				local chatService = game:GetService("TextChatService")
				if chatService and chatService.TextChannels then
					local general = chatService.TextChannels:FindFirstChild("RBXGeneral")
					if general then
						general:SendAsync(word)
						return
					end
				end
				game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
					:FindFirstChild("SayMessageRequest"):FireServer(word, "All")
			end)
			if not ok then
				pcall(function()
					VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Slash, false, game)
					task.wait(0.05)
					VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Slash, false, game)
					task.wait(0.1)
					for c in word:gmatch(".") do
						local kc = Enum.KeyCode[c:upper()]
						if kc then
							VirtualInputManager:SendKeyEvent(true, kc, false, game)
							task.wait(0.01)
							VirtualInputManager:SendKeyEvent(false, kc, false, game)
						end
					end
					task.wait(0.05)
					VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
					task.wait(0.02)
					VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
				end)
			end
		end)
	end
	
