	local function rebuildConfigList()
		if not configListFrame or not configEntryTemplate then return end
		for _, child in ipairs(configListFrame:GetChildren()) do
			if child:IsA("Frame") and child.Name ~= "configTemplate" then
				child:Destroy()
			end
		end
		local names = getConfigNames()
		local ySize = 30
		local yPad = 4
		local yStart = 4
		for i, name in ipairs(names) do
			local entry = configEntryTemplate:Clone()
			entry.Name = "entry_" .. name
			entry.Visible = true
			entry.Position = UDim2.new(0, 0, 0, yStart + (i-1) * (ySize + yPad))
			entry.Size = UDim2.new(1, 0, 0, ySize)
			local label = entry:FindFirstChild("label")
			local deleteBtn = entry:FindFirstChild("deleteBtn")
			if label then label.Text = name end
			entry.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					if selectedConfigEntry and selectedConfigEntry ~= entry then
						selectedConfigEntry.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
					end
					selectedConfigEntry = entry
					entry.BackgroundColor3 = Color3.fromRGB(55, 145, 230)
				end
			end)
			entry.InputBegan:Connect(function(input)
				if input.KeyCode == Enum.KeyCode.F2 and selectedConfigEntry == entry then
					if renamingFrame then return end
					renamingFrame = entry
					local oldName = label and label.Text or ""
					local renameBox = Instance.new("TextBox")
					renameBox.Size = UDim2.new(1, -40, 1, 0)
					renameBox.Position = UDim2.new(0, 0, 0, 0)
					renameBox.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
					renameBox.TextColor3 = Color3.fromRGB(255, 255, 255)
					renameBox.Text = oldName
					renameBox.Font = Enum.Font.GothamMedium
					renameBox.TextSize = 13
					renameBox.ZIndex = 10
					renameBox.Parent = entry
					renameBox:CaptureFocus()
					local finished = false
					local function finishRename()
						if finished then return end
						finished = true
						local newName = renameBox.Text:gsub("[^%w_%-]", "_")
						pcall(function() renameBox:Destroy() end)
						renamingFrame = nil
						if newName == "" or newName == oldName then
							rebuildConfigList()
							return
						end
						local loaded = loadConfig(oldName)
						if loaded then
							local saved = saveConfig(newName)
							if saved then
								deleteConfig(oldName)
								notify("Lunar X", "Renamed '" .. oldName .. "' to '" .. newName .. "'", 4, "success")
							else
								notify("Lunar X", "Failed to save renamed config", 4, "error")
							end
						else
							notify("Lunar X", "Failed to load config for rename", 4, "error")
						end
						if selectedConfigEntry == entry then selectedConfigEntry = nil end
						rebuildConfigList()
					end
					renameBox.FocusLost:Connect(finishRename)
					renameBox.InputBegan:Connect(function(inp)
						if inp.KeyCode == Enum.KeyCode.Return then
							finishRename()
						elseif inp.KeyCode == Enum.KeyCode.Escape then
							finished = true
							pcall(function() renameBox:Destroy() end)
							renamingFrame = nil
							rebuildConfigList()
						end
					end)
				end
			end)
			if deleteBtn then
				deleteBtn.MouseButton1Click:Connect(function()
					local entryName = label and label.Text or ""
					if entryName == "" then return end
					local ok = deleteConfig(entryName)
					if ok then
						notify("Lunar X", "Deleted config: " .. entryName, 4, "success")
						if selectedConfigEntry == entry then selectedConfigEntry = nil end
						rebuildConfigList()
					else
						notify("Lunar X", "Failed to delete: " .. entryName, 4, "error")
					end
				end)
			end
			entry.Parent = configListFrame
		end
		local totalH = yStart + #names * (ySize + yPad)
		configListFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(totalH, configListFrame.AbsoluteSize.Y))
	end
	
