local function C_a()
local script = G2L["a"];
	local btnsFolder = script.Parent
	local frmsFolder = btnsFolder.Parent:WaitForChild("_frms")
	
	local buttonMap = {
		hbtn = "hfrm",
		obtn = "ofrm",
		mbtn = "mfrm",
		ebtn = "efrm"
	}
	
	local buttons = {}
	local frames = {}
	
	for btnName, frmName in pairs(buttonMap) do
		buttons[btnName] = btnsFolder:WaitForChild(btnName)
		frames[frmName] = frmsFolder:WaitForChild(frmName)
	end 
	
	local function showFrame(targetFrm)
		for _, frm in pairs(frames) do
			frm.Visible = (frm == targetFrm)
		end
	end
	
	local function updateBorders(activeBtn)
		for _, btn in pairs(buttons) do
			if btn:FindFirstChild("brd") then
				btn.brd.Visible = (btn == activeBtn)
			end
		end
	end
	
	for btnName, btn in pairs(buttons) do
		local targetFrameName = buttonMap[btnName]
		local correspondingFrame = frames[targetFrameName]
	
		btn.MouseButton1Click:Connect(function()
			showFrame(correspondingFrame)
			updateBorders(btn)
		end)
	end
	
	for btnName, btn in pairs(buttons) do
		local targetFrameName = buttonMap[btnName]
		local correspondingFrame = frames[targetFrameName]
	
		if correspondingFrame and correspondingFrame.Visible then
			updateBorders(btn)
			break
		end
	end
end;
