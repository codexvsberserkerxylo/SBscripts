	local function calcEstWpm()
		local avgLen = math.max(avgWordLenTracked, 1)
		if state.randomSpeed then
			local mn = math.max(state.minSpeed or 0.04, 0.001)
			local mx = math.max(state.maxSpeed or 0.1, 0.001)
			local avg = (mn + mx) / 2
			if avg <= 0 then return "inf" end
			return math.floor((1 / avg) / avgLen * 60)
		else
			local spd = state.normalSpeed or 0.15
			if spd <= 0 then return "inf" end
			return math.floor((1 / spd) / avgLen * 60)
		end
	end
	
