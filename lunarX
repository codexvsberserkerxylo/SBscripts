	local function doLegitCorrection(partial, setTextFn, targetWord, typoInsertedAt)
		local baseLen = #partial
		local extraCount = math.random(1, 3)
		for e = 1, extraCount do
			if not state.autoType then
				partial = partial:sub(1, baseLen - 1)
				setTextFn(partial)
				return partial
			end
			local ni = typoInsertedAt + e
			local ec = (ni <= #targetWord) and getTypoChar(targetWord:sub(ni, ni))
				or getTypoChar(targetWord:sub(#targetWord, #targetWord))
			partial = partial .. ec
			setTextFn(partial)
			local spd = math.max(state.normalSpeed, 0.02)
			task.wait(spd)
		end
		local deleteCount = #partial - baseLen + 1
		for d = 1, deleteCount do
			if not state.autoType then break end
			task.wait(0.04 + math.random() * 0.1)
			partial = partial:sub(1, -2)
			setTextFn(partial)
		end
		return partial
	end
	
	local function doNoFixDelete(word, setTextFn)
		local typoCount = state.noFixDeleteThreshold or 4
		local indices = {}
		for i = 1, #word do indices[#indices+1] = i end
		for i = #indices, 2, -1 do
			local j = math.random(1, i)
			indices[i], indices[j] = indices[j], indices[i]
		end
		local chosen = {}
		for i = 1, math.min(typoCount, #indices - 1) do
			chosen[indices[i]] = true
		end
		local result = ""
		for i = 1, #word do
			result = result .. (chosen[i] and getTypoChar(word:sub(i,i)) or word:sub(i,i))
		end
		for i = 1, #result do
			if not state.autoType then return result end
			setTextFn(result:sub(1, i))
			updateLettersLabel(i, #word)
			task.wait(getTypingSpeed())
			maybeRandomPause(i)
		end
		task.wait(0.08 + math.random() * 0.12)
		local current = result
		for i = 1, #word do
			if not state.autoType then return word end
			if current:sub(i,i) ~= word:sub(i,i) then
				current = current:sub(1, i-1) .. word:sub(i,i) .. current:sub(i+1)
				setTextFn(current)
				task.wait(0.03 + math.random() * 0.06)
			end
		end
		return word
	end
	
	local function doHesitateTypo(partial, setTextFn, targetWord, i)
		task.wait(0.15 + math.random() * 0.25)
		return partial
	end
	
	local function doDoubleTypeTypo(partial, setTextFn, targetWord, i)
		local char = targetWord:sub(i, i)
		partial = partial .. char
		setTextFn(partial)
		task.wait(0.03 + math.random() * 0.05)
		partial = partial:sub(1, -2)
		setTextFn(partial)
		task.wait(0.04 + math.random() * 0.08)
		return partial
	end
	
	local function applyTypoToChar(partial, setTextFn, targetWord, i, typoCountRef, resetCountRef)
		local char = targetWord:sub(i, i)
		local method = state.typoMethod
		resetCountRef = resetCountRef or 0
	
		if method == "Hesitate" then
			partial = doHesitateTypo(partial, setTextFn, targetWord, i)
			return partial, typoCountRef, false, i+1, resetCountRef
	
		elseif method == "Double Type" then
			partial = doDoubleTypeTypo(partial, setTextFn, targetWord, i)
			return partial, typoCountRef, false, i+1, resetCountRef
	
		elseif method == "Legit" then
			typoCountRef = typoCountRef + 1
			partial = partial .. getTypoChar(char)
			setTextFn(partial)
			partial = doLegitCorrection(partial, setTextFn, targetWord, i)
			setTextFn(partial)
			return partial, typoCountRef, false, i, resetCountRef
	
		elseif method == "Fix" then
			typoCountRef = typoCountRef + 1
			partial = partial .. getTypoChar(char)
			setTextFn(partial)
			task.wait(getContWait())
			partial = partial:sub(1, -2)
			setTextFn(partial)
			return partial, typoCountRef, false, i, resetCountRef
	
		elseif method == "No Fix" then
			typoCountRef = typoCountRef + 1
			partial = partial .. getTypoChar(char)
			setTextFn(partial)
			return partial, typoCountRef, false, i+1, resetCountRef
	
		elseif method == "Full Delete" then
			typoCountRef = typoCountRef + 1
			partial = partial .. getTypoChar(char)
			setTextFn(partial)
			task.wait(getContWait())
			if typoCountRef >= state.fullDeleteThreshold then
				if resetCountRef >= 3 then
					partial = ""
					setTextFn(partial)
					return partial, 0, true, 1, resetCountRef
				end
				local extra = math.random(1, 2)
				for e = 1, extra do
					if not state.autoType then break end
					local ni = i + e
					local ec = ni <= #targetWord and getTypoChar(targetWord:sub(ni,ni)) or getTypoChar(char)
					partial = partial .. ec
					setTextFn(partial)
					task.wait(math.random() * 0.05 + 0.02)
				end
				partial = ""
				typoCountRef = 0
				setTextFn(partial)
				task.wait(0.04)
				return partial, typoCountRef, true, 1, resetCountRef+1
			else
				partial = partial:sub(1, -2)
				setTextFn(partial)
				return partial, typoCountRef, false, i, resetCountRef
			end
	
		elseif method == "No Fix Delete" then
			return partial, typoCountRef, false, i, resetCountRef
		end
	
		return partial, typoCountRef, false, i, resetCountRef
	end
	
	local function checkLoseAfterWords()
		if not state.loseAfterWords then return end
		if state.wordsTyped >= state.loseCount then
			state.autoType = false
			state.wordsTyped = 0
			updateToggleBar(atBtn, false)
		end
	end
	
	local function autoSayWord(word)
		if not state.autoSayEnabled then return end
		if not word or word == "" then return end
		local delay = math.max(state.autoSayDelay, 0)
		task.spawn(function()
			task.wait(delay)
			if not state.autoSayEnabled then return end
			local sent = false
			pcall(function()
				local chatService = game:GetService("TextChatService")
				if chatService and chatService.TextChannels then
					local general = chatService.TextChannels:FindFirstChild("RBXGeneral")
					if general then
						general:SendAsync(word)
						sent = true
					end
				end
			end)
			if sent then return end
			pcall(function()
				local chatEvents = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
				if chatEvents then
					local req = chatEvents:FindFirstChild("SayMessageRequest")
					if req then
						req:FireServer(word, "All")
						sent = true
					end
				end
			end)
			if sent then return end
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Slash, false, game)
				task.wait(0.05)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Slash, false, game)
				task.wait(0.1)
				for c in word:gmatch(".") do
					local kc = Enum.KeyCode[c:upper()]
					if kc then
						VirtualInputManager:SendKeyEvent(true, kc, false, game)
						task.wait(0.01)
						VirtualInputManager:SendKeyEvent(false, kc, false, game)
					end
				end
				task.wait(0.05)
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
				task.wait(0.02)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
			end)
		end)
	end
	
