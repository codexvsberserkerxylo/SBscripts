	local function typeWordVIM(word, textbox)
		if textbox then
			textbox:CaptureFocus()
			task.wait(0.05)
		end
		for i = 1, #word do
			if not state.autoType then break end
			local char = word:sub(i, i)
			local upper = char:upper()
			local kc = Enum.KeyCode[upper]
			if kc then
				VirtualInputManager:SendKeyEvent(true, kc, false, game)
				task.wait(0.01)
				VirtualInputManager:SendKeyEvent(false, kc, false, game)
			end
			updateLettersLabel(i, #word)
			maybeRandomPause(i)
			if i < #word then task.wait(getTypingSpeed()) end
		end
	end
	
	local function runTypingLoop(targetWord, startIndex, endIndex, setTextFn, guardFn)
		local partialWord = ""
	
		if state.typosEnabled and state.typoMethod == "No Fix Delete" then
			partialWord = doNoFixDelete(targetWord, setTextFn)
			setTextFn(partialWord)
			return partialWord
		end
	
		local typoCount = 0
		local resetCount = 0
		local i = startIndex
		while i <= endIndex do
			if not guardFn() then break end
			local char = targetWord:sub(i, i)
			local shouldTypo = state.typosEnabled
				and math.random(1, 100) <= state.typoChance
				and i < endIndex
			if shouldTypo then
				local np, nc, didReset, ni, nr = applyTypoToChar(partialWord, setTextFn, targetWord, i, typoCount, resetCount)
				partialWord = np
				typoCount = nc
				resetCount = nr
				i = didReset and 1 or ni
				setTextFn(partialWord)
				continue
			end
			partialWord = partialWord .. char
			updateLettersLabel(#partialWord, #targetWord)
			setTextFn(partialWord)
			maybeRandomPause(#partialWord)
			if i < endIndex then task.wait(getTypingSpeed()) end
			i = i + 1
		end
		return partialWord
	end
	
