if not game:IsLoaded() then
	game.Loaded:Wait()
end
local p = game:GetService("Players")
local lp = p.LocalPlayer

local bP = 1.0
local pI = 0.015
local mP = 2.25

local function setup(player)
	local pg = player:FindFirstChildOfClass("PlayerGui")
	if not pg then return end

	local s = Instance.new("Sound")
	s.Name = "osu"
	s.SoundId = "rbxassetid://7172607676" -- sound
	s.Volume = 0.8
	s.Parent = player

	local function apply(box)
		if box:GetAttribute("SoundHooked") then return end
		box:SetAttribute("SoundHooked", true)
		
		box:GetPropertyChangedSignal("Text"):Connect(function()
			local textLength = #box.Text
			local cPi = textLength == 0 and bP or math.min(bP + (textLength * pI), mP)
			
			s.PlaybackSpeed = cPi
			s:Stop()
			s.TimePosition = 0
			s:Play()
		end)
	end

	local function hook(gui)
		if gui.Name == "Type" then
			gui:GetPropertyChangedSignal("Enabled"):Connect(function()
				if gui.Enabled then
					s.PlaybackSpeed = bP
					s:Stop()
					s.TimePosition = 0
					s:Play()
				end
			end)

			local txt = gui:FindFirstChildWhichIsA("TextBox", true)
			if txt then apply(txt) end
			
			gui.DescendantAdded:Connect(function(desc)
				if desc:IsA("TextBox") then apply(desc) end
			end)
		end
	end

	for _, child in ipairs(pGui:GetChildren()) do
		hook(child)
	end
	pg.ChildAdded:Connect(hook)
end

for _, player in ipairs(p:GetPlayers()) do
	task.spawn(setup, player)
end

p.PlayerAdded:Connect(setup)
